# ---------------------------------------------------------------------------
# CP Tracker environment configuration
# Copy to `.env` for local runs. In GitHub Actions these come from Secrets.
# ---------------------------------------------------------------------------

# Platform accounts
LEETCODE_USERNAME=Reyhaan-S
CODEFORCES_HANDLE=Reyhaan
ATCODER_USERNAME=Reyhaan

# ----- Google Sheets -------------------------------------------------------
# Existing spreadsheet (append-only target). Taken from the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS PART>/edit
GOOGLE_SHEET_ID=1VKV9kIzNWpXArqZXlg6xTK3OgvFiqumf9UCqlna2iJA

# Tab (worksheet) name that contains the tracking table
GOOGLE_SHEET_NAME=Sheet1

# Credentials — set EXACTLY ONE of the two options below.
#
# Option A (recommended, matches GitHub Actions): the full service-account
# JSON, base64-encoded to survive as a single line:
#   base64 -w 0 service-account.json          (Linux)
#   base64 -i service-account.json | tr -d '\n'   (macOS)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option B (local dev): path to the downloaded JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ----- Optional tuning -----------------------------------------------------
# REQUEST_TIMEOUT=20
# MAX_RETRIES=4
# RETRY_BACKOFF_BASE=2
# LEETCODE_FETCH_LIMIT=40
# CODEFORCES_FETCH_COUNT=50
# LOG_LEVEL=INFO
